---
import { siteConfig } from "../config/site";
---

<section class="hero shell">
  <div class="hero-copy">
    <span class="eyebrow fade-in">Personal site</span>
    <h1 class="fade-in delay-1">{siteConfig.name}</h1>
    <p class="lede fade-in delay-2">{siteConfig.intro}</p>
    <p class="support fade-in delay-3">{siteConfig.status}</p>
    <div class="button-row fade-in delay-3">
      <a class="button button-primary" href="#projects">Selected work</a>
      <a class="button button-secondary" href="#contact">Links</a>
    </div>
  </div>
</section>

<style>
  .hero {
    display: block;
    padding: 6rem 0 4rem;
  }

  .hero-copy {
    max-width: 42rem;
  }

  h1 {
    margin: 1rem 0 1rem;
    font-family: "Instrument Serif", serif;
    font-size: clamp(3.8rem, 10vw, 7rem);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .lede {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.65;
  }

  .support {
    max-width: 36rem;
    margin: 1.2rem 0 2rem;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .hero {
      padding: 5rem 0 3rem;
    }
  }
</style>
